<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="20220619-008-1" author="lzugaj" >
        <createTable tableName="hypertension">
            <column name="condition_measurement_id" type="UUID">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="systolic" type="INT">
                <constraints nullable="false" />
            </column>

            <column name="diastolic" type="INT">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20220619-008-2" author="lzugaj">
        <addForeignKeyConstraint
                constraintName="fk_hypertension_condition_measurement"
                baseTableName="hypertension"
                baseColumnNames="condition_measurement_id"
                referencedTableName="condition_measurement"
                referencedColumnNames="id"
        />
    </changeSet>

</databaseChangeLog>
