<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="20220619-007-1" author="lzugaj" >
        <createTable tableName="condition_measurement">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="measured_at" type="DATETIME">
                <constraints unique="true" nullable="false" />
            </column>

            <column name="modified_at" type="DATETIME">
                <constraints nullable="false" />
            </column>

            <column name="user_id" type="UUID">
                <constraints nullable="false" />
            </column>

            <column name="condition_id" type="UUID">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20220619-007-2" author="lzugaj">
        <addForeignKeyConstraint
                constraintName="fk_user_condition_measurement"
                baseTableName="condition_measurement"
                baseColumnNames="user_id"
                referencedTableName="user"
                referencedColumnNames="id"
        />
    </changeSet>

    <changeSet id="20220619-007-3" author="lzugaj">
        <addForeignKeyConstraint
                constraintName="fk_condition_measurement"
                baseTableName="condition_measurement"
                baseColumnNames="condition_id"
                referencedTableName="condition"
                referencedColumnNames="id"
        />
    </changeSet>

</databaseChangeLog>
